{
  "name": "@genflow/analyzer",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "AST-based dependency analyzer (ts-morph) + CLI + Fastify server for GenFlow.",
  "bin": {
    "genflow-analyze": "src/index.ts"
  },
  "scripts": {
    "analyze": "tsx src/index.ts",
    "server": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.1",
    "adm-zip": "^0.5.16",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "fastify": "^5.1.0",
    "ts-morph": "^24.0.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
